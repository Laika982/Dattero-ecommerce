<body class="bg-surface text-on-surface antialiased overflow-x-hidden selection:bg-secondary/30 selection:text-primary">
<!-- TopNavBar Component -->
<nav class="fixed top-0 w-full z-50 bg-surface/95 dark:bg-surface/90 backdrop-blur-md border-b border-secondary/10 dark:border-secondary-fixed-dim/10 shadow-sm transition-all duration-300 shadow-md" id="main-nav">
<div class="flex justify-between items-center w-full px-container-padding max-w-max-width mx-auto h-20">
<!-- Brand Logo -->
<a class="font-headline-lg text-headline-lg font-bold text-on-surface tracking-tight z-10 flex-shrink-0" href="#">
                Nutri Burfi
            </a>
<!-- Navigation Links (Desktop) -->
<div class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
<a class="text-on-surface font-label-md text-label-md border-b-2 border-on-surface pb-1" href="/">Home</a>
<a class="text-on-surface-variant font-label-md text-label-md hover:text-on-surface transition-colors" href="products">Products</a>
<a class="text-on-surface-variant font-label-md text-label-md hover:text-on-surface transition-colors" href="about">About Us</a>
<a class="text-on-surface-variant font-label-md text-label-md hover:text-on-surface transition-colors" href="contact">Contact</a>
</div>
<!-- Trailing Icon Actions -->
<div class="flex items-center gap-4 text-on-surface z-10 flex-shrink-0">
<button class="hover:opacity-80 transition-opacity active:scale-95 duration-150 ease-in-out p-2 rounded-full hover:bg-surface-variant/50">
<span class="material-symbols-outlined" data-icon="search">search</span>
</button>
<button class="hover:opacity-80 transition-opacity active:scale-95 duration-150 ease-in-out p-2 rounded-full hover:bg-surface-variant/50">
<span class="material-symbols-outlined" data-icon="favorite">favorite</span>
</button>
<button class="hover:opacity-80 transition-opacity active:scale-95 duration-150 ease-in-out p-2 rounded-full hover:bg-surface-variant/50 relative">
<span class="material-symbols-outlined" data-icon="shopping_cart">shopping_cart</span>
<span class="absolute top-1 right-1 w-2 h-2 bg-accent-blue rounded-full"></span>
</button>
<div class="relative hidden md:block">
<button id="user-menu-btn" class="hover:opacity-80 transition-opacity active:scale-95 duration-150 ease-in-out p-2 rounded-full hover:bg-surface-variant/50">
<span class="material-symbols-outlined" data-icon="person">person</span>
</button>
<div id="user-dropdown" class="absolute right-0 mt-3 w-48 rounded-2xl bg-white border border-secondary/15 shadow-xl py-2 hidden z-50">
{{#if user}}
<a href="/logout" class="flex items-center gap-3 px-4 py-3 text-label-md text-error hover:bg-error-container/20 transition-colors">
<span class="material-symbols-outlined text-[20px]" data-icon="logout">logout</span>
Logout
</a>
{{else}}
<a href="/login" class="flex items-center gap-3 px-4 py-3 text-label-md text-on-surface hover:bg-surface-container-low transition-colors">
<span class="material-symbols-outlined text-[20px]" data-icon="login">login</span>
Login
</a>
{{/if}}
</div>
</div>
<!-- Mobile Menu Toggle -->
<button class="md:hidden hover:opacity-80 transition-opacity active:scale-95 duration-150 ease-in-out p-2 rounded-full hover:bg-surface-variant/50 ml-2" id="mobile-menu-btn">
<span class="material-symbols-outlined" data-icon="menu">menu</span>
</button>
</div>
