<a class="font-headline-lg text-headline-lg py-4 border-b border-secondary/10" href="#">Contact</a>
<a class="font-headline-lg text-headline-lg py-4 border-b border-secondary/10 flex items-center justify-between" href="#">Account <span class="material-symbols-outlined">person</span></a>
</div>