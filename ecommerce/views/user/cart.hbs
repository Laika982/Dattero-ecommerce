{{>user/header}}
<!-- Main Content -->
<main class="flex-grow w-full max-w-max-width mx-auto px-8 py-section-gap">
<header class="mb-stack-lg text-center md:text-left">
<h1 class="font-display-lg-mobile md:font-display-lg text-ink-black mb-4">Your Cart</h1>
<p class="font-body-lg text-ink-black/60">Review your premium selections before checkout.</p>
</header>
<div class="flex flex-col lg:flex-row gap-8">
<!-- Cart Items List (Left Side) -->
<div class="w-full lg:w-2/3 flex flex-col gap-6">
<!-- Item 1: Dates Burfi -->
<div class="bg-surface-container-lowest rounded-[24px] p-8 flex flex-col sm:flex-row items-start sm:items-center gap-8 relative">
<div class="w-full sm:w-32 h-32 bg-surface-gray rounded-[16px] overflow-hidden relative shrink-0">
<img alt="Dates Burfi" class="object-cover w-full h-full mix-blend-multiply" data-alt="A close-up, high-end editorial shot of premium Dates Burfi, resting on a textured cream slate. The lighting is soft and directional, highlighting the rich, dark brown texture of the dates and the subtle glint of embedded nuts. The composition is minimalistic, embodying a quiet luxury aesthetic perfect for a high-protein luxury brand. The background is a soft, out-of-focus cream color." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCR5Tq_O_dP6Ib3J9AcCXvni2rC2_TOx8CeTwwpwNhF6YvcTbMh3PoqCTNt6TAn6gTt-8gvV_v575_h80q1NpxZyeSXjFDNqEwL4DntOivijB1tjna-RPct95RxdxZq39P9nTywtYBLJeMl-N3kCyefbsTwyennVpNmHRBytEkMsykZzpHKkuKrzZn80SJ1BxevSWa9upC78MoKPjx8Lpr23F-76mNvxtYEH83ppJDyMq-hbMEUI8WVmTEMuF2N0GNHEEzu_xc6Axo">
</div>
<div class="flex-grow flex flex-col justify-between h-full w-full">
<div>
<div class="flex justify-between items-start mb-2">
<h3 class="font-headline-lg text-[24px] text-ink-black leading-tight">Signature Dates Burfi</h3>
<button aria-label="Remove item" class="text-ink-black/40 hover:text-ink-black transition-colors p-1">
<span class="material-symbols-outlined" data-icon="close">close</span>
</button>
</div>
<span class="font-label-md text-ink-black/60 inline-block mb-3">High Protein • Vegan</span>
<p class="font-body-md text-ink-black/60 mb-4">500g Box - Artisan crafted with premium Medjool dates.</p>
</div>
<div class="flex justify-between items-center mt-auto">
<div class="flex items-center gap-4 bg-surface-gray rounded-full px-2 py-1">
<button class="w-8 h-8 flex items-center justify-center text-ink-black/60 hover:text-ink-black transition-colors rounded-full font-label-md">−</button>
<span class="w-6 text-center font-label-md text-ink-black">1</span>
<button class="w-8 h-8 flex items-center justify-center text-ink-black/60 hover:text-ink-black transition-colors rounded-full font-label-md">+</button>
</div>
<span class="font-headline-lg text-[24px] text-ink-black">$34.00</span>
</div>
</div>
</div>
<!-- Item 2: Protein Bar -->
<div class="bg-surface-container-lowest rounded-[24px] p-8 flex flex-col sm:flex-row items-start sm:items-center gap-8 relative">
<div class="w-full sm:w-32 h-32 bg-surface-gray rounded-[16px] overflow-hidden relative shrink-0">
<img alt="Protein Bar" class="object-cover w-full h-full mix-blend-multiply" data-alt="A sleek, modern product shot of a dark chocolate protein bar partially unwrapped, lying diagonally across a pristine white marble surface. Soft, diffused lighting casts a gentle ambient shadow, emphasizing the bar's rugged, protein-packed texture and glossy chocolate coating. Small gold leaf flakes are subtly scattered nearby to reinforce the premium, Elevated Minimalism aesthetic. High contrast, sharp focus." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYDBvlrFHFSn5yYA73xd6uIwkGTl1V4BCM3NjKJSqoghbcgQ2GWlp4t7WSW4AmPrE-1o6r_YJgWTvnwXCb-iE0hA1UtUtYdnjK5z06ZwaajTC3kssXVhn2ZVsEKv8HsP0Pv-r5joxhxfFOgikNdPYB71-5bowijBMvhUEuOjSh5e81pa-SsWPE2vjWH_2DQ2CGsu7S9JvWGxksR6GKVS_amuknYvwaR9RUd6LWZQhAF_-Z6-ud-mrrNF7AUN8OSIHrf0VxYibsLtU">
</div>
<div class="flex-grow flex flex-col justify-between h-full w-full">
<div>
<div class="flex justify-between items-start mb-2">
<h3 class="font-headline-lg text-[24px] text-ink-black leading-tight">Dark Cocoa Protein Bar</h3>
<button aria-label="Remove item" class="text-ink-black/40 hover:text-ink-black transition-colors p-1">
<span class="material-symbols-outlined" data-icon="close">close</span>
</button>
</div>
<span class="font-label-md text-ink-black/60 inline-block mb-3">20g Protein</span>
<p class="font-body-md text-ink-black/60 mb-4">Box of 12 - Pre/Post workout premium fuel.</p>
</div>
<div class="flex justify-between items-center mt-auto">
<div class="flex items-center gap-4 bg-surface-gray rounded-full px-2 py-1">
<button class="w-8 h-8 flex items-center justify-center text-ink-black/60 hover:text-ink-black transition-colors rounded-full font-label-md">−</button>
<span class="w-6 text-center font-label-md text-ink-black">2</span>
<button class="w-8 h-8 flex items-center justify-center text-ink-black/60 hover:text-ink-black transition-colors rounded-full font-label-md">+</button>
</div>
<span class="font-headline-lg text-[24px] text-ink-black">$48.00</span>
</div>
</div>
</div>
<!-- Continue Shopping Link -->
<div class="mt-4">
<a class="inline-flex items-center text-ink-black font-label-md hover:text-accent-blue transition-colors group" href="#">
<span class="material-symbols-outlined mr-2 text-[18px] group-hover:-translate-x-1 transition-transform" data-icon="arrow_back">arrow_back</span>
                        Continue Shopping
                    </a>
</div>
</div>
<!-- Order Summary Sidebar (Right Side) -->
<div class="w-full lg:w-1/3">
<div class="bg-surface-container-lowest rounded-[24px] p-8 sticky top-32">
<h2 class="font-headline-lg text-[24px] text-ink-black mb-8">Order Summary</h2>
<div class="flex flex-col gap-4 mb-8">
<div class="flex justify-between items-center">
<span class="font-body-md text-ink-black/60">Subtotal (3 items)</span>
<span class="font-body-lg text-ink-black">$82.00</span>
</div>
<div class="flex justify-between items-center">
<span class="font-body-md text-ink-black/60">Shipping Estimate</span>
<span class="font-body-lg text-ink-black">$5.00</span>
</div>
<div class="flex justify-between items-center">
<span class="font-body-md text-ink-black/60">Estimated Tax</span>
<span class="font-body-lg text-ink-black">$6.56</span>
</div>
</div>
<div class="w-full h-px bg-surface-gray mb-8"></div>
<!-- Coupon Code -->
<div class="mb-8">
<label class="block font-label-md text-ink-black/60 mb-3" for="coupon">Gift Card or Discount Code</label>
<div class="flex gap-3">
<input class="w-full bg-surface-gray border-none rounded-[12px] px-4 py-3 font-body-md text-ink-black focus:outline-none focus:ring-2 focus:ring-accent-blue/50 transition-shadow placeholder:text-ink-black/40" id="coupon" placeholder="Enter code" type="text">
<button class="bg-ink-black/5 text-ink-black font-label-md px-6 py-3 rounded-[12px] hover:bg-ink-black/10 transition-colors whitespace-nowrap">Apply</button>
</div>
</div>
<div class="w-full h-px bg-surface-gray mb-8"></div>
<div class="flex justify-between items-center mb-8">
<span class="font-headline-lg text-[24px] text-ink-black">Grand Total</span>
<span class="font-headline-xl text-ink-black">$93.56</span>
</div>
<button class="w-full bg-ink-black text-white font-label-md py-4 rounded-[16px] hover:opacity-90 transition-opacity flex items-center justify-center group">
                        Proceed to Checkout
                        <span class="material-symbols-outlined ml-2 group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
</button>
<p class="text-center font-body-md text-[13px] text-ink-black/40 mt-4">Taxes and shipping calculated at checkout.</p>
</div>
</div>
</div>
</main>
{{>user/footer}}