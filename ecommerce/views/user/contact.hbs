{{>user/header}}
<!-- Main Content Canvas -->
<main class="flex-grow w-full max-w-max-width mx-auto px-container-padding py-section-gap">
<!-- Header -->
<div class="text-center mb-section-gap max-w-2xl mx-auto">
<h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-stack-md">Get in Touch</h1>
<p class="font-body-xl text-body-xl text-on-surface-variant">We're here to answer any questions about our artisanal protein sweets. Reach out to our dedicated team.</p>
</div>
<!-- Split Layout: Contact Form & Details -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-grid-gutter mb-section-gap">
<!-- Contact Form (Left) -->
<div class="bg-surface-container-lowest p-8 md:p-12 border border-outline-variant/30 rounded-[24px] shadow-sm flex flex-col justify-center">
<h2 class="font-headline-lg text-headline-lg text-on-surface mb-stack-lg">Send a Message</h2>
<form class="space-y-stack-lg">
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
<div class="input-wrapper relative">
<label class="block font-label-md text-label-md text-on-surface-variant mb-2">First Name</label>
<input class="w-full bg-surface-gray border border-outline-variant/20 rounded-[12px] focus:ring-2 focus:ring-accent-blue focus:border-accent-blue focus:bg-white px-4 py-3 font-body-lg text-body-lg text-on-surface transition-all" placeholder="Jane" type="text">
</div>
<div class="input-wrapper relative">
<label class="block font-label-md text-label-md text-on-surface-variant mb-2">Last Name</label>
<input class="w-full bg-surface-gray border border-outline-variant/20 rounded-[12px] focus:ring-2 focus:ring-accent-blue focus:border-accent-blue focus:bg-white px-4 py-3 font-body-lg text-body-lg text-on-surface transition-all" placeholder="Doe" type="text">
</div>
</div>
<div class="input-wrapper relative">
<label class="block font-label-md text-label-md text-on-surface-variant mb-2">Email Address</label>
<input class="w-full bg-surface-gray border border-outline-variant/20 rounded-[12px] focus:ring-2 focus:ring-accent-blue focus:border-accent-blue focus:bg-white px-4 py-3 font-body-lg text-body-lg text-on-surface transition-all" placeholder="jane@example.com" type="email">
</div>
<div class="input-wrapper relative">
<label class="block font-label-md text-label-md text-on-surface-variant mb-2">Inquiry Type</label>
<select class="w-full bg-surface-gray border border-outline-variant/20 rounded-[12px] focus:ring-2 focus:ring-accent-blue focus:border-accent-blue focus:bg-white px-4 py-3 font-body-lg text-body-lg text-on-surface transition-all cursor-pointer">
<option>General Question</option>
<option>Wholesale Inquiry</option>
<option>Order Support</option>
<option>Press &amp; Media</option>
</select>
</div>
<div class="input-wrapper relative">
<label class="block font-label-md text-label-md text-on-surface-variant mb-2">Message</label>
<textarea class="w-full bg-surface-gray border border-outline-variant/20 rounded-[12px] focus:ring-2 focus:ring-accent-blue focus:border-accent-blue focus:bg-white px-4 py-3 font-body-lg text-body-lg text-on-surface transition-all resize-none" placeholder="How can we help you today?" rows="4"></textarea>
</div>
<div class="pt-stack-md">
<button class="w-full bg-ink-black text-white font-label-md text-label-md py-4 px-6 rounded-[16px] hover:opacity-90 transition-opacity" type="submit">Send Inquiry</button>
</div>
</form>
</div>
<!-- Contact Details & Map (Right) -->
<div class="flex flex-col gap-stack-lg">
<!-- Details Card -->
<div class="bg-surface-container-lowest p-8 md:p-12 border border-outline-variant/30 rounded-[24px] shadow-sm h-full flex flex-col justify-center">
<h3 class="font-headline-lg text-headline-lg text-on-surface mb-stack-lg">Contact Information</h3>
<ul class="space-y-8">
<li class="flex items-start">
<span class="material-symbols-outlined text-ink-black mr-4 mt-1" style="font-variation-settings: 'FILL' 1;">location_on</span>
<div>
<p class="font-label-md text-label-md text-on-surface-variant mb-1">Headquarters</p>
<p class="font-body-lg text-body-lg text-on-surface">123 Artisan Way, Suite 400<br>Culinary District, NY 10001</p>
</div>
</li>
<li class="flex items-start">
<span class="material-symbols-outlined text-ink-black mr-4 mt-1" style="font-variation-settings: 'FILL' 1;">phone</span>
<div>
<p class="font-label-md text-label-md text-on-surface-variant mb-1">Phone</p>
<p class="font-body-lg text-body-lg text-on-surface">+1 (800) 555-BURF</p>
<p class="font-body-md text-body-md text-on-surface-variant mt-1">Mon-Fri, 9am - 5pm EST</p>
</div>
</li>
<li class="flex items-start">
<span class="material-symbols-outlined text-ink-black mr-4 mt-1" style="font-variation-settings: 'FILL' 1;">mail</span>
<div>
<p class="font-label-md text-label-md text-on-surface-variant mb-1">Email</p>
<p class="font-body-lg text-body-lg text-on-surface">hello@nutriburfi.com</p>
</div>
</li>
</ul>
<div class="mt-8 pt-8 border-t border-outline-variant/30">
<p class="font-label-md text-label-md text-on-surface-variant mb-4">Follow Our Journey</p>
<div class="flex space-x-4">
<a class="w-12 h-12 rounded-full border border-outline-variant/30 flex items-center justify-center text-on-surface hover:border-ink-black hover:text-ink-black transition-colors" href="#">
<span class="material-symbols-outlined">share</span>
</a>
<a class="w-12 h-12 rounded-full border border-outline-variant/30 flex items-center justify-center text-on-surface hover:border-ink-black hover:text-ink-black transition-colors" href="#">
<span class="material-symbols-outlined">photo_camera</span>
</a>
<a class="w-12 h-12 rounded-full border border-outline-variant/30 flex items-center justify-center text-on-surface hover:border-ink-black hover:text-ink-black transition-colors" href="#">
<span class="material-symbols-outlined">play_arrow</span>
</a>
</div>
</div>
</div>
<!-- Embedded Map Mockup -->
<div class="relative w-full h-64 md:h-80 bg-surface-gray rounded-[24px] overflow-hidden border border-outline-variant/30">
<!-- Map Image Placeholder -->
<div class="absolute inset-0 bg-cover bg-center" data-alt="A clean, minimalist high-end digital map interface centered on New York City, featuring a subtle cream and beige color palette with thin, elegant dark brown roads. A small, stylized gold map pin marks the center location. The lighting is soft and flat, emphasizing the UI aesthetic of a luxury brand contact page." data-location="New York City" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAATYzPAxLDmFp3vlj_7K2UlVVEp-w-rN9U8ENEMZavo3mBrwyKb54IdhKLcqqyT7hcmvvQVpddbuusgvrMOChccOTul3BBUln_fIP3UI_-qN7Jyrw13qvYj5WfVrLjXB-mY0DycKGBqsoMqNx_mzdd3CXEdYSBjeGGRcQMDgn2t9JL1-p_BNzsHQD3LMJ5Huh2-pz00rP6eOOcYlLVa1y3U5uO21ZkvU6DhyIiqYvxtuh3eKVapJ-ko2VsWNpGSKtSooonaAI6lhk')"></div>
</div>
</div>
</div>
<!-- FAQ Section -->
<div class="max-w-3xl mx-auto mb-section-gap">
<h2 class="font-headline-xl text-display-lg-mobile md:text-headline-xl text-on-surface text-center mb-stack-lg">Frequently Asked Questions</h2>
<div class="space-y-4">
<details class="bg-surface-container-lowest border border-outline-variant/30 rounded-[16px] overflow-hidden shadow-sm group">
<summary class="flex justify-between items-center p-6 font-headline-lg text-[20px] text-on-surface font-semibold hover:bg-surface-gray transition-colors">
                        What is the shelf life of your protein sweets?
                        <span class="material-symbols-outlined text-on-surface-variant accordion-icon">expand_more</span>
</summary>
<div class="p-6 pt-0 font-body-lg text-body-lg text-on-surface-variant">
                        Our handcrafted protein sweets are made without artificial preservatives. They maintain peak freshness and flavor for up to 14 days when stored in a cool, dry place. For extended freshness, you may refrigerate them for up to 30 days.
                    </div>
</details>
<details class="bg-surface-container-lowest border border-outline-variant/30 rounded-[16px] overflow-hidden shadow-sm group">
<summary class="flex justify-between items-center p-6 font-headline-lg text-[20px] text-on-surface font-semibold hover:bg-surface-gray transition-colors">
                        Do you offer wholesale purchasing for gyms and cafes?
                        <span class="material-symbols-outlined text-on-surface-variant accordion-icon">expand_more</span>
</summary>
<div class="p-6 pt-0 font-body-lg text-body-lg text-on-surface-variant">
                        Yes, we offer competitive wholesale pricing for premium fitness centers, health-focused cafes, and boutique grocers. Please select "Wholesale Inquiry" in the contact form above, and our partnerships team will reach out within 24 hours.
                    </div>
</details>
<details class="bg-surface-container-lowest border border-outline-variant/30 rounded-[16px] overflow-hidden shadow-sm group">
<summary class="flex justify-between items-center p-6 font-headline-lg text-[20px] text-on-surface font-semibold hover:bg-surface-gray transition-colors">
                        Are your products suitable for vegan diets?
                        <span class="material-symbols-outlined text-on-surface-variant accordion-icon">expand_more</span>
</summary>
<div class="p-6 pt-0 font-body-lg text-body-lg text-on-surface-variant">
                        We offer a dedicated line of plant-based protein burfis made with high-quality pea and rice protein isolates, sweetened naturally. Look for the "Vegan" chip on our product cards in the shop section.
                    </div>
</details>
<details class="bg-surface-container-lowest border border-outline-variant/30 rounded-[16px] overflow-hidden shadow-sm group">
<summary class="flex justify-between items-center p-6 font-headline-lg text-[20px] text-on-surface font-semibold hover:bg-surface-gray transition-colors">
                        How long does shipping usually take?
                        <span class="material-symbols-outlined text-on-surface-variant accordion-icon">expand_more</span>
</summary>
<div class="p-6 pt-0 font-body-lg text-body-lg text-on-surface-variant">
                        To ensure optimal freshness, all orders are shipped out on Mondays and Tuesdays using expedited 2-day shipping. Orders placed after Tuesday afternoon will be shipped the following Monday.
                    </div>
</details>
</div>
</div>
</main>
{{>user/footer}}